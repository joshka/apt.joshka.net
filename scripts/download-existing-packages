#!/usr/bin/env bash

set -euo pipefail

# shellcheck source=common
source "$(dirname "$0")/common"

output_dir=${1:-"$repo_root/build/packages"}
manifest=${2:-}
install -d "$output_dir"

for command in curl gzip awk; do
  need_command "$command"
done

work_dir=$(mktemp -d)
trap 'rm -rf "$work_dir"' EXIT
filenames="$work_dir/filenames"
: >"$filenames"

for architecture in amd64 arm64; do
  index_url="$REPOSITORY_URL/dists/$REPOSITORY_SUITE/$REPOSITORY_COMPONENT/binary-$architecture/Packages.gz"
  if ! curl --fail --location --silent --show-error "$index_url" --output "$work_dir/Packages.gz"; then
    echo "No existing $architecture index at $REPOSITORY_URL"
    continue
  fi
  gzip -dc "$work_dir/Packages.gz" |
    awk '/^Filename: / { print substr($0, 11) }' >>"$filenames"
done

sort -u "$filenames" -o "$filenames"
if [[ -n $manifest ]]; then
  install -d "$(dirname "$manifest")"
  cp "$filenames" "$manifest"
fi

while IFS= read -r filename; do
  output="$output_dir/${filename##*/}"
  curl --fail --location --retry 3 --silent --show-error \
    "$REPOSITORY_URL/$filename" --output "$output"
done <"$filenames"
