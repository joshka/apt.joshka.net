#!/usr/bin/env bash

set -euo pipefail

# shellcheck source=common
source "$(dirname "$0")/common"

usage() {
  echo "usage: $0 <version> <amd64|arm64>" >&2
  exit 2
}

[[ $# == 2 ]] || usage
version=$(normalize_version "$1")
architecture=$(debian_architecture "$2")

if command -v podman >/dev/null 2>&1 && podman info >/dev/null 2>&1; then
  container=(podman)
elif command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
  container=(docker)
elif command -v colima >/dev/null 2>&1 && colima status >/dev/null 2>&1; then
  container=(colima ssh -- env DOCKER_API_VERSION=1.43 docker)
else
  die 'a running Podman, Docker, or Colima environment is required'
fi

platform="linux/$architecture"
image="apt-joshka-net-build:$architecture"
"${container[@]}" build --platform "$platform" --tag "$image" \
  --file "$repo_root/containers/Containerfile" "$repo_root"
"${container[@]}" run --rm --platform "$platform" \
  --volume "$repo_root:/workspace" \
  "$image" scripts/build-package "$version" "$architecture"
